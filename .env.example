# CallCoach CRM - Environment Variables (Hostinger Cloud)
# Copy this to .env and fill in your values

# Environment: set to "production" on Hostinger server
ENV=production

# REQUIRED: PostgreSQL connection string
DATABASE_URL=postgresql://callcoach:YOUR_DB_PASSWORD@localhost:5432/callcoach_db

# REQUIRED: Your Anthropic API Key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# REQUIRED: Secret key for JWT auth tokens (generate a random 64-char string)
SECRET_KEY=generate-a-random-64-character-string-here

# Optional: Claude model (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Whisper model size for transcription (tiny, base, small, medium, large-v3)
WHISPER_MODEL=base

# Optional: Groq API key for Whisper transcription (get from console.groq.com)
GROQ_API_KEY=

# Optional: Cloudflare R2 storage for call recordings
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=callcoach-recordings
R2_PUBLIC_URL=
