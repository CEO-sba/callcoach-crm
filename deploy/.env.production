# CallCoach CRM - Production Environment Variables
# Copy this to /opt/callcoach-crm/.env and fill in real values

# REQUIRED: Your Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# REQUIRED: PostgreSQL connection string
DATABASE_URL=postgresql://callcoach:CHANGE_THIS_PASSWORD@localhost:5432/callcoach_db

# REQUIRED: Secret key for JWT tokens (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=GENERATE_A_RANDOM_SECRET_KEY

# Claude model
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Whisper model for transcription
WHISPER_MODEL=base

# Server port
PORT=8000
